<UserControl x:Class="WebForms2BlazorWASM.Dialog.MigrateWebFormDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="480" Height="320">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Migrating WebForm to Blazor WASM..."
                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <!-- Status scroll -->
        <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" Background="#F8F8F8">
            <ScrollViewer x:Name="scrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="statusPanel" Margin="10"/>
            </ScrollViewer>
        </Border>

        <!-- Close button — only enabled after migration completes -->
        <Button Grid.Row="2" x:Name="btnClose"
                Content="Close" Width="80" Height="28"
                HorizontalAlignment="Right" Margin="0,12,0,0"
                IsEnabled="False" Click="Close_Click"/>
    </Grid>

</UserControl>
